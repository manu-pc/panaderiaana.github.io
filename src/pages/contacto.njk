{% extends "layouts/base.njk" %}
{% block body %}
{% include "partials/pagehead.njk" %}

{% set i = content.intro %}
<section class="section center">
  <div class="container reveal">
    <p class="eyebrow">{{ i.eyebrow }}</p>
    <h2>{{ i.title }}</h2>
    <p class="measure mx-auto">{{ i.text }}</p>
    <a href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener" class="btn btn--primary">
      <svg class="icon" aria-hidden="true"><use href="#i-whatsapp"/></svg>{{ i.whatsapp }}
    </a>
  </div>
</section>

{% set sc = content.schedule %}
<section class="section section--alt">
  <div class="container reveal">
    <h2 class="center">{{ sc.title }}</h2>
    <table class="schedule">
      {% for r in sc.rows %}
      <tr>
        <td>{{ r.day }}</td>
        <td class="{{ 'closed' if r.closed }}">{{ r.hours }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>
</section>

<section class="section center">
  <div class="container reveal">
    <h2>{{ content.map.title }}</h2>
    <div class="map-embed">
      <iframe src="{{ site.mapEmbed }}" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen title="{{ content.map.title }}"></iframe>
    </div>
  </div>
</section>

{% set d = content.dev %}
<section class="section devbox center">
  <div class="container reveal">
    <h2>{{ d.title }}</h2>
    <p class="measure mx-auto">{{ d.text }}</p>
    <p style="margin-top:1.5rem"><strong>{{ site.dev.name }}</strong></p>
    <p><a href="mailto:{{ site.dev.email }}">{{ site.dev.email }}</a></p>
    <p><a href="{{ site.dev.github }}" target="_blank" rel="noopener"><svg class="icon" aria-hidden="true"><use href="#i-github"/></svg> {{ site.dev.githubLabel }}</a></p>
  </div>
</section>
{% endblock %}
